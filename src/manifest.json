{
  "manifest_version": 3,
  "name": "Late Meet",
  "version": "1.1.0",
  "description": "AI meeting copilot for Google Meet with local-first transcription and summaries",
  "permissions": ["storage", "tabs", "tabCapture", "offscreen", "sidePanel", "notifications"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://api.openai.com/*",
    "https://api.elevenlabs.io/*"
  ],
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["src/content.ts"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/options.html",
  "side_panel": {
    "default_path": "src/dashboard.html"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Late Meet"
  },
  "icons": {
    "128": "src/icons/icon128.png"
  }
}
